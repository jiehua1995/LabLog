{
  "name": "lablog",
  "version": "0.1.1",
  "description": "Desktop markdown template generator for lab notes.",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:css && electron .",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/output.css --minify",
    "build:css:watch": "tailwindcss -i ./css/input.css -o ./css/output.css --watch",
    "dist": "npm run build:css && electron-builder --publish never",
    "release": "npm run build:css && electron-builder"
  },
  "author": {
    "name": "Jie Hua",
    "email": "Jie.Hua@lmu.de"
  },
  "homepage": "https://github.com/jiehua1995/Lablog",
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "daisyui": "^5.5.19",
    "electron": "^41.0.3",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "electron-updater": "^6.8.3",
    "theme-change": "^2.5.0",
    "vditor": "^3.11.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jiehua1995/LabLog"
  }
}
